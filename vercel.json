{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": ".",
      "framework": "nextjs"
    },
    "eve": {
      "root": ".",
      "framework": "eve",
      "buildCommand": "eve build"
    }
  },
  "rewrites": [
    {
      "source": "/_eve_internal/eve/:path*",
      "destination": {
        "service": "eve",
        "path": "/:path*"
      }
    }
  ]
}
