# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Database — one URL variable plus the auth token is required on serverless hosts.
# Leave them unset locally to use file:.data/db.sqlite.
# Serverless deployments require a hosted libSQL database because the local
# filesystem is not durable.
# Provision via the Turso integration on the Vercel Marketplace (`vercel integration add turso`)
# and these are set automatically. TURSO_DATABASE_URL is preferred.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# Compatibility alias for existing environments, used only when the preferred name is unset.
# TURSO_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-auth-token
