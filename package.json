{
  "name": "first-response-agent-poc",
  "version": "0.0.0",
  "description": "A first-response support PoC built with Eve, Next.js, and Better Auth",
  "license": "MIT",
  "author": "Hugo Richard",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel-labs/personal-agent-template"
  },
  "bugs": {
    "url": "https://github.com/vercel-labs/personal-agent-template/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*"
  },
  "scripts": {
    "build": "pnpm build:eve && next build",
    "build:eve": "eve build",
    "dev": "next dev",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "ai": "^7.0.16",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "eve": "^0.20.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "react-doctor": "^0.7.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
